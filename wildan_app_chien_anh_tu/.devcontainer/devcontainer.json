{
  "name": "Flutter Team Workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dart-code.flutter",
        "dart-code.dart-code",
        "Nash.awesome-flutter-snippets"
      ]
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "flutter doctor && flutter pub get",
  "remoteUser": "vscode"
}